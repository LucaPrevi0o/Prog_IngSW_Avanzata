# Local development configuration. Copy this file to .env.
# This origin is allowed by Rails CORS.
FRONTEND_ORIGIN=http://localhost:4200

# URL used by the Angular development server to reach Rails.
API_BASE_URL=http://localhost:3000

# Local demonstration administrator, created idempotently by `make setup`.
# Do not reuse these credentials outside local development.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=secret123

# Docker Compose ports. The browser uses the frontend port; nginx proxies /api.
COMPOSE_FRONTEND_PORT=8080
COMPOSE_BACKEND_PORT=3000
